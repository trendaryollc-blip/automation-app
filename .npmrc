# pnpm configuration for workspace
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=true

# Use official registry with robust retry behavior
registry=https://registry.npmjs.org

# Increase network timeout for slow connections
network-timeout=600000

# Retry more often with longer waits between retries
fetch-retries=8
fetch-retry-mintimeout=30000
fetch-retry-maxtimeout=180000

# Lower concurrency to reduce timeout pressure on slow networks
max-concurrency=1
