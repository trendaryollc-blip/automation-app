{
  "name": "@workspace/api-server",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --require ./dist/env.cjs --enable-source-maps ./dist/index.mjs",
    "pretypecheck": "pnpm --filter @workspace/db run build --if-present && pnpm --filter @workspace/api-zod run build --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vercel-build": "node ./build.mjs",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "13.2.0",
    "helmet": "^8.1.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "typescript": "catalog:"
  }
}
