.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Project-specific: temp / debug artifacts that should never be committed.
# These were accidentally added to the repository at the project root
# during initial development.  Keeping them out prevents deploys and CI
# runs from picking up stale state.
# ---------------------------------------------------------------------------

# Throwaway log/output files written by `node ... > temp-*.txt`
temp-*.log
temp-*.txt
temp-*.out
temp-*.err

# One-off debugging entry points
debug-*.mjs
debug-*.ts
debug-*.js
