{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "project": "dropflow",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/dropflow/dist",
  "framework": "vite",
  "devCommand": "pnpm run dev",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.mjs": {
      "runtime": "nodejs@22.x",
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
