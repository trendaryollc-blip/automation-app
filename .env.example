# ============================================================================
# DropFlow — Environment Variables
# Copy to `.env` and fill in the values for your local / staging /
# production environment.  NEVER commit a real `.env` to source control.
# ============================================================================

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------

NODE_ENV=development
PORT=8080
HOST=127.0.0.1
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Database
#
# Choose one of: postgres (default) or firestore.
#   - For postgres set DATABASE_URL below.
#   - For firestore set DB_MODE=firestore and either
#       GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
#     OR
#       FIREBASE_PROJECT_ID, FIREBASE_CLIENT_EMAIL, FIREBASE_PRIVATE_KEY
# ----------------------------------------------------------------------------

DB_MODE=postgres
DATABASE_URL=postgresql://user:password@localhost:5432/dropflow

# Firestore (only required if DB_MODE=firestore)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----------------------------------------------------------------------------
# Authentication
#
# JWT_SECRET is REQUIRED in production and must be at least 32 characters.
# Generate one with:  openssl rand -hex 32
# In development a per-process fallback is used, which means every server
# restart invalidates all sessions.
# ----------------------------------------------------------------------------

JWT_SECRET=replace-me-with-a-32-plus-character-random-secret

# ----------------------------------------------------------------------------
# Public signup control
#
# SIGNUP_ENABLED controls whether the public /api/auth/signup endpoint
# is reachable.  Set to "false" in production to disable self-serve
# signup and use invite-only provisioning instead.
# ----------------------------------------------------------------------------

SIGNUP_ENABLED=true

# ----------------------------------------------------------------------------
# CORS
#
# CORS_ORIGIN is a single origin or a comma-separated list of allowed
# origins for browser-based clients.  In development the API is served
# from the same origin as the frontend through the Vite proxy, so the
# default of "*" is safe.  In production you MUST set this to the
# exact origin of your deployed frontend, e.g.
#   CORS_ORIGIN=https://app.dropflow.com
# The server will REFUSE TO BOOT in production if this is "*" or unset.
# ----------------------------------------------------------------------------

CORS_ORIGIN=*

# ----------------------------------------------------------------------------
# Frontend (Vite)
#
# VITE_API_URL is the URL the browser uses to reach the API.  In dev,
# the Vite proxy at /api forwards to the local API server, so you can
# leave the default.  In production, set this to the absolute origin
# of the deployed API, e.g. https://api.dropflow.com.
# If unset, the app falls back to the same origin (recommended for the
# Vercel serverless setup where frontend and API share a domain).
# ----------------------------------------------------------------------------

VITE_API_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# Application URL (used for password-reset / verify links)
# ----------------------------------------------------------------------------

APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Email (Resend-compatible)
#
# The API sends transactional email through a simple HTTP service.
# By default emails are written to the server log (DEV mode) and NOT
# actually sent, so development never leaks real customer email
# addresses.  Set EMAIL_PROVIDER=resend + RESEND_API_KEY to enable
# real delivery in production.
# ----------------------------------------------------------------------------

EMAIL_PROVIDER=log
EMAIL_FROM="DropFlow <no-reply@dropflow.local>"
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com

# ----------------------------------------------------------------------------
# Error reporting (Sentry-compatible)
#
# Set SENTRY_DSN to enable automatic error capture on the API server.
# The frontend reads VITE_SENTRY_DSN at build time.  Both are optional
# in development.
# ----------------------------------------------------------------------------

SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----------------------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------------------

# When true, /api/auth/signup is open to the public.  When false, only
# invitation is supported (admin creates the account).
SIGNUP_ENABLED=true

# ----------------------------------------------------------------------------
# External integrations (optional)
# ----------------------------------------------------------------------------

# CJ Dropshipping — https://developers.cjdropshipping.com/
# CJ_API_KEY=
# CJ_API_SECRET=
# CJ_BASE_URL=https://api.cjdropshipping.com

# Zendrop — https://www.zendrop.com/
# ZENDROP_API_KEY=
# ZENDROP_BASE_URL=https://api.zendrop.com
